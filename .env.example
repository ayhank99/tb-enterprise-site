CMS_PASSWORD=din_starke_kode

# Optional: persistent CMS + media storage for Vercel/server deployments.
# Falls back to CHAT_DATABASE_URL if CMS_DATABASE_URL is not set.
# Leave commented to use the local JSON/public uploads fallback in /data and /public/uploads.
# CMS_DATABASE_URL=postgres://user:password@host:5432/database
# CMS_DATABASE_SSL=true

# Optional: GitHub-backed CMS + media storage.
# Useful if you want admin saves/uploads to write directly into the GitHub repo
# and let Vercel redeploy from those commits.
# If omitted, owner/repo/branch can be inferred on Vercel from linked Git metadata.
# GITHUB_CONTENTS_TOKEN=github_pat_xxx
# GITHUB_REPO_OWNER=ayhank99
# GITHUB_REPO_NAME=tb-enterprise-site
# GITHUB_REPO_BRANCH=main

# Optional: persistent chat storage for server deployments.
# Leave commented to use the local JSON fallback in /data/chat-state.json.
# CHAT_DATABASE_URL=postgres://user:password@host:5432/database
# CHAT_DATABASE_SSL=true

# Optional: preview deployment in a subfolder, for example /preview
# NEXT_PUBLIC_SITE_BASE_PATH=/preview
# NEXT_PUBLIC_SITE_IS_PREVIEW=true
# NEXT_PUBLIC_DISABLE_QUOTE_SUBMIT=true

# Optional: override the quote form endpoint.
# Leave commented if quote-handler.php is placed in the same deploy root as the website.
# Development defaults to /api/quote and production defaults to /quote-handler.php
# NEXT_PUBLIC_QUOTE_ENDPOINT=/preview/quote-handler.php
